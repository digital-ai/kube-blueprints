apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  {{- if eq .UseCustomNamespace true }}
  name: {{ .Namespace }}-xlr-operator-manager
  {{- else }}
  name: xlr-operator-manager
  {{- end }}
rules:
{{- if eq .K8sSetup "Openshift" }}
- apiGroups:
    - ""
  resources:
    - namespaces
  verbs:
    - "get"
    - "list"
- apiGroups:
    - policy
  resources:
    - poddisruptionbudgets
  verbs:
    - '*'
- apiGroups:
    - route.openshift.io
  resources:
    - '*'
  verbs:
    - '*'
{{- end }}
